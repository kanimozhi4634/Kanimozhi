    </div>

    <!-- Hobbies -->
    <div class="box">
        <h2 class="gradient-text">Hobbies</h2>
        <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:25px; margin-top:15px;">
            <div class="hobby-item">
                <i class="fas fa-film" style="font-size:40px; color:#00ffcc;"></i>
                <p>Watching Movies</p>
            </div>
            <div class="hobby-item">
                <i class="fas fa-book" style="font-size:40px; color:#00ffcc;"></i>
                <p>Reading Books</p>
            </div>
        </div>
    </div>

    <!-- Contact Info -->
    <div class="box">
        <h2 class="gradient-text">Contact Me</h2>
        <p><i class="fas fa-phone"></i> +91 6374461347</p>
        <p><i class="fas fa-envelope"></i> <a href="mailto:kanimozhi4634@gmail.com">kanimozhi4634@gmail.com</a></p>
    </div>

    <footer>
        Thank you for visiting my website. Designed by R Kanimozhi | 2026 <br>
        Contact: +91 6374461347 | <a href="mailto:kanimozhi4634@gmail.com">kanimozhi4634@gmail.com</a>
    </footer>
</div>

<script>
    const glow = document.getElementById("glow");
    document.addEventListener("mousemove",(e)=>{
        glow.style.left=e.clientX+"px";
        glow.style.top=e.clientY+"px";
    });

    const boxes = document.querySelectorAll('.box');
    function checkBoxes() {
        const triggerBottom = window.innerHeight / 5 * 4;
        boxes.forEach(box => {
            const boxTop = box.getBoundingClientRect().top;
            if(boxTop < triggerBottom){ box.classList.add('visible'); }
        });
    }
    window.addEventListener('scroll', checkBoxes);
    checkBoxes();
</script>

</body>
</html>
